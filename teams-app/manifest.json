{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.16/MicrosoftTeams.schema.json",
  "manifestVersion": "1.16",
  "version": "1.2.0",
  "id": "20110dcf-795b-4f7c-8180-9cdbb8e39ffc",
  "developer": {
    "name": "Ranger & Fox",
    "websiteUrl": "https://rangerandfox.tv",
    "privacyUrl": "https://rangerandfox.tv/privacy",
    "termsOfUseUrl": "https://rangerandfox.tv/terms"
  },
  "name": {
    "short": "RF Studio Bot",
    "full": "Ranger & Fox Studio Bot"
  },
  "description": {
    "short": "Provision projects and create storyboards",
    "full": "The unified Ranger & Fox studio assistant. Provision new projects across 6 platforms and parse scripts into AI-powered storyboards with Boords and ElevenLabs."
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#FF0028",
  "bots": [
    {
      "botId": "20110dcf-795b-4f7c-8180-9cdbb8e39ffc",
      "scopes": ["personal", "team", "groupChat"],
      "supportsFiles": true,
      "isNotificationOnly": false,
      "commandLists": [
        {
          "scopes": ["personal", "team", "groupChat"],
          "commands": [
            {
              "title": "newproject",
              "description": "Provision a new project across all platforms"
            },
            {
              "title": "storyboard",
              "description": "Parse a script into a visual storyboard"
            },
            {
              "title": "help",
              "description": "Show all available commands"
            }
          ]
        }
      ]
    }
  ],
  "permissions": ["identity", "messageTeamMembers"],
  "validDomains": ["rf-studio-bot.pages.dev"]
}
